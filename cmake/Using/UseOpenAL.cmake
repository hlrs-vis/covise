MACRO(USE_OPENAL)
  IF ((NOT OPENAL_FOUND) AND (${ARGC} LESS 1))
    USING_MESSAGE("Skipping because of missing OPENAL")
    RETURN()
  ENDIF((NOT OPENAL_FOUND) AND (${ARGC} LESS 1))
  IF(NOT OPENAL_USED AND OPENAL_FOUND)
    SET(OPENAL_USED TRUE)
	ADD_DEFINITIONS(-DHAVE_OPENAL)
    INCLUDE_DIRECTORIES(SYSTEM ${OPENAL_INCLUDE_DIR})
    SET(EXTRA_LIBS ${EXTRA_LIBS} ${OPENAL_LIBRARIES})
  ENDIF()
ENDMACRO(USE_OPENAL)

